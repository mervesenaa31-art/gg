<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>❤️ Sürpriz ❤️</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    overflow:hidden;
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    flex-direction:column;
    background:linear-gradient(135deg,#ff758c,#ff7eb3);
    transition:1s;
}

button{
    padding:18px 40px;
    font-size:24px;
    border:none;
    border-radius:50px;
    background:#fff;
    color:#ff2d55;
    cursor:pointer;
    font-weight:bold;
    box-shadow:0 10px 25px rgba(0,0,0,.2);
    transition:.3s;
}

button:hover{
    transform:scale(1.1);
}

#mesaj{
    margin-top:40px;
    color:white;
    font-size:50px;
    text-align:center;
    opacity:0;
    transform:scale(.5);
    transition:.6s;
    text-shadow:0 0 20px rgba(255,255,255,.7);
}

.kalp{
    position:absolute;
    color:red;
    font-size:25px;
    animation:uc 4s linear forwards;
    user-select:none;
}

@keyframes uc{
    0%{
        transform:translateY(0) scale(1);
        opacity:1;
    }
    100%{
        transform:translateY(-900px) rotate(720deg) scale(2);
        opacity:0;
    }
}
</style>

</head>
<body>

<button onclick="surpriz()">💖 Bana Tıkla 💖</button>

<div id="mesaj"></div>

<script>

const mesajlar=[
"❤️ Seni Seviyorum ❤️",
"🥰 Sen Benim Her Şeyimsin 🥰",
"💘 İyi ki Varsın 💘",
"🌹 Kalbim Hep Seninle 🌹",
"💕 Sonsuza Kadar Sen 💕",
"💖 Dünyamın En Güzeli 💖",
"😍 Gülüşün Her Şeye Değer 😍"
];

const renkler=[
"linear-gradient(135deg,#ff758c,#ff7eb3)",
"linear-gradient(135deg,#ff9966,#ff5e62)",
"linear-gradient(135deg,#f953c6,#b91d73)",
"linear-gradient(135deg,#fc6076,#ff9a44)",
"linear-gradient(135deg,#ff6a88,#ff99ac)"
];

function surpriz(){

let mesaj=document.getElementById("mesaj");

mesaj.innerHTML=mesajlar[Math.floor(Math.random()*mesajlar.length)];
mesaj.style.opacity="1";
mesaj.style.transform="scale(1)";

document.body.style.background=
renkler[Math.floor(Math.random()*renkler.length)];

for(let i=0;i<40;i++){
kalpOlustur();
}

}

function kalpOlustur(){

let kalp=document.createElement("div");

kalp.className="kalp";
kalp.innerHTML="❤";

kalp.style.left=Math.random()*100+"vw";
kalp.style.top="100vh";
kalp.style.fontSize=(20+Math.random()*40)+"px";

document.body.appendChild(kalp);

setTimeout(()=>{
kalp.remove();
},4000);

}

</script>

</body>
</html>
